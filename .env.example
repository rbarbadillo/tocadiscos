# =============================================================================
# Required
# =============================================================================

# Last.fm API - Get yours at https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key
LASTFM_USERNAME=your_lastfm_username

# LLM Provider - "mistral" (default) or "anthropic"
LLM_PROVIDER=mistral

# Mistral API - Get yours at https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key

# Anthropic API (optional) - Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# =============================================================================
# Observability (Langfuse) - https://cloud.langfuse.com
# =============================================================================

LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# Notifications (Optional)
# =============================================================================

# Email via Resend - https://resend.com
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev
EMAIL_TO=your_email@example.com
